[Unit]
Description=REX FinHub Send Gate Auto-Open (for the 5:45 PM scheduled send)

[Service]
Type=oneshot
# Pin process timezone to ET (audit fix R7).
Environment=TZ=America/New_York
ExecStart=/bin/bash -c 'echo true > /home/jarvis/rexfinhub/config/.send_enabled && logger -t rexfinhub-gate "gate opened by timer"'
User=jarvis
