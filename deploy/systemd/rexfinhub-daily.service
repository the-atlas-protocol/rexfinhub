[Unit]
Description=REX FinHub Daily Pipeline (full sync + email reports)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=rexfinhub
WorkingDirectory=/home/rexfinhub/rexfinhub
EnvironmentFile=/home/rexfinhub/rexfinhub/config/.env
Environment=SEC_CACHE_DIR=/home/rexfinhub/rexfinhub/cache/sec
ExecStart=/home/jarvis/venv/bin/python scripts/run_daily.py
TimeoutStartSec=7200
StandardOutput=journal
StandardError=journal
