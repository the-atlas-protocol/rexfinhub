[Unit]
Description=Close send gate weekdays 20:00 ET — ~30 min after daily pipeline finishes

[Timer]
# 2026-04-28 cadence flip: was 18:15 (paired with old 17:45 daily); moved
# to 20:00 to pair with new 19:30 daily timer. Daily takes 10-20 min;
# 20:00 gives a safe buffer. Any send attempt after this hits the closed
# gate until the next 19:00.
OnCalendar=Mon..Fri 20:00:00
Persistent=false

[Install]
WantedBy=timers.target
