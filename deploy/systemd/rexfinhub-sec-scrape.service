[Unit]
Description=REX FinHub SEC Filing Scrape
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=rexfinhub
WorkingDirectory=/home/rexfinhub/rexfinhub
EnvironmentFile=/home/rexfinhub/rexfinhub/config/.env
Environment=SEC_CACHE_DIR=/home/rexfinhub/rexfinhub/cache/sec
ExecStart=/usr/bin/python3.13 scripts/run_all_pipelines.py --skip-email --skip-market
TimeoutStartSec=3600
StandardOutput=journal
StandardError=journal
