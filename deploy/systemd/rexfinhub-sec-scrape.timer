[Unit]
Description=REX FinHub SEC Scrape Timer (4x daily, weekdays)

[Timer]
# VPS timezone set to America/New_York — DST handled automatically
OnCalendar=Mon..Fri 08:00:00
OnCalendar=Mon..Fri 12:00:00
OnCalendar=Mon..Fri 16:00:00
OnCalendar=Mon..Fri 20:00:00
Persistent=true

[Install]
WantedBy=timers.target
